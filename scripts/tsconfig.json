{
  "compilerOptions": {
    "module": "nodenext",
    "lib": [
      "ESNext",
      "DOM"
    ],
    "noEmit": true,
    "rootDir": "../scripts/",
    "strict": true,
    "sourceMap": true,
    "moduleResolution": "nodenext",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": [
      "node",
      "vscode"
    ]
  },
  "include": [
    "../scripts/"
  ]
}
