{
  "name": "svg-all-in-one",
  "displayName": "SVG All in One",
  "description": "All-in-one SVG toolkit for VS Code: split preview editing, optimize/format, PNG export, color tools, diagnostics, and smart completion.",
  "version": "0.1.0",
  "publisher": "RobinZhao",
  "license": "MIT",
  "icon": "resources/marketplace/icon.png",
  "galleryBanner": {
    "color": "#0F172A",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other",
    "Formatters",
    "Visualization"
  ],
  "keywords": [
    "svg",
    "svg-editor",
    "png",
    "svgo",
    "xml",
    "vector",
    "icon",
    "diagnostics",
    "completion"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Robin-zero/SVG-All-in-One.git"
  },
  "activationEvents": [
    "onLanguage:svg",
    "onCommand:svgAllInOne.openPanel",
    "onCommand:svgAllInOne.editAttribute",
    "onCommand:svgAllInOne.addAttribute",
    "onCommand:svgAllInOne.removeAttribute",
    "onCommand:svgAllInOne.exportPng",
    "onCommand:svgAllInOne.exportPngVariants",
    "onCommand:svgAllInOne.quickRecolor",
    "onCommand:svgAllInOne.cleanupSvg",
    "onCommand:svgAllInOne.compressSvg",
    "onCommand:svgAllInOne.formatSvg",
    "onCommand:svgAllInOne.extractPalette"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "svgAllInOne.openPanel",
        "title": "SVG All in One: Open Split Editor + Preview",
        "icon": {
          "light": "resources/light/open-preview.svg",
          "dark": "resources/dark/open-preview.svg"
        }
      },
      {
        "command": "svgAllInOne.exportPng",
        "title": "SVG All in One: Export PNG",
        "icon": {
          "light": "resources/light/export-png.svg",
          "dark": "resources/dark/export-png.svg"
        }
      },
      {
        "command": "svgAllInOne.exportPngVariants",
        "title": "SVG All in One: Export PNG Variants (@1x/@2x/@3x)"
      },
      {
        "command": "svgAllInOne.quickRecolor",
        "title": "SVG All in One: Quick Recolor"
      },
      {
        "command": "svgAllInOne.cleanupSvg",
        "title": "SVG All in One: Cleanup Useless XML"
      },
      {
        "command": "svgAllInOne.compressSvg",
        "title": "SVG All in One: Compress SVG (SVGO)"
      },
      {
        "command": "svgAllInOne.formatSvg",
        "title": "SVG All in One: Format SVG"
      },
      {
        "command": "svgAllInOne.extractPalette",
        "title": "SVG All in One: Extract Color Palette"
      },
      {
        "command": "svgAllInOne.editAttribute",
        "title": "SVG All in One: Edit Selected Attribute"
      },
      {
        "command": "svgAllInOne.addAttribute",
        "title": "SVG All in One: Add Attribute"
      },
      {
        "command": "svgAllInOne.removeAttribute",
        "title": "SVG All in One: Remove Attribute"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "svgAllInOne.attributePanel",
          "name": "SVG Selected Node Attributes"
        }
      ]
    },
    "menus": {
      "editor/title": [
        {
          "command": "svgAllInOne.openPanel",
          "when": "resourceExtname == .svg",
          "group": "navigation@1"
        },
        {
          "command": "svgAllInOne.exportPng",
          "when": "resourceExtname == .svg",
          "group": "navigation@2"
        }
      ],
      "explorer/context": [
        {
          "command": "svgAllInOne.openPanel",
          "when": "resourceExtname == .svg",
          "group": "navigation"
        },
        {
          "command": "svgAllInOne.exportPng",
          "when": "resourceExtname == .svg",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "svgAllInOne.addAttribute",
          "when": "view == svgAllInOne.attributePanel",
          "group": "navigation@1"
        },
        {
          "command": "svgAllInOne.removeAttribute",
          "when": "view == svgAllInOne.attributePanel",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "svgAllInOne.editAttribute",
          "when": "view == svgAllInOne.attributePanel && viewItem == svgAttribute",
          "group": "inline@1"
        },
        {
          "command": "svgAllInOne.removeAttribute",
          "when": "view == svgAllInOne.attributePanel && viewItem == svgAttribute",
          "group": "inline@2"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "package:vsix": "npx @vscode/vsce package --no-dependencies"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@xmldom/xmldom": "^0.8.10",
    "svgo": "^3.3.2",
    "xml-formatter": "^3.6.7"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/vscode": "^1.95.0",
    "typescript": "^5.8.2"
  }
}
