{
  "name": "svg-all-in-one",
  "displayName": "SVG All in One",
  "description": "All-in-one SVG toolkit for VS Code: split preview editing, optimize/format, PNG export, color tools, diagnostics, and smart completion.",
  "version": "0.1.1",
  "publisher": "RobinZhao",
  "license": "MIT",
  "icon": "resources/marketplace/icon.png",
  "galleryBanner": {
    "color": "#F1F5F9",
    "theme": "light"
  },
	"l10n": "./l10n",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other",
    "Formatters",
    "Visualization"
  ],
  "keywords": [
    "svg",
    "svg-editor",
    "png",
    "svgo",
    "xml",
    "vector",
    "icon",
    "diagnostics",
    "completion"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Robin-zero/SVG-All-in-One.git"
  },
  "activationEvents": [
    "onLanguage:svg"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "svgAllInOne.openPanel",
        "title": "%svgAllInOne.openPanel.title%",
        "shortTitle": "%svgAllInOne.openPanel.short%",
        "icon": {
          "light": "resources/light/open-preview.svg",
          "dark": "resources/dark/open-preview.svg"
        }
      },
      {
        "command": "svgAllInOne.exportPng",
        "title": "%svgAllInOne.exportPng.title%",
        "shortTitle": "%svgAllInOne.exportPng.short%",
        "icon": {
          "light": "resources/light/export-png.svg",
          "dark": "resources/dark/export-png.svg"
        }
      },
      {
        "command": "svgAllInOne.exportPngVariants",
        "title": "%svgAllInOne.exportPngVariants.title%",
        "shortTitle": "%svgAllInOne.exportPngVariants.short%"
      },
      {
        "command": "svgAllInOne.quickRecolor",
        "title": "%svgAllInOne.quickRecolor.title%",
        "shortTitle": "%svgAllInOne.quickRecolor.short%"
      },
      {
        "command": "svgAllInOne.cleanupSvg",
        "title": "%svgAllInOne.cleanupSvg.title%",
        "shortTitle": "%svgAllInOne.cleanupSvg.short%"
      },
      {
        "command": "svgAllInOne.compressSvg",
        "title": "%svgAllInOne.compressSvg.title%",
        "shortTitle": "%svgAllInOne.compressSvg.short%"
      },
      {
        "command": "svgAllInOne.formatSvg",
        "title": "%svgAllInOne.formatSvg.title%",
        "shortTitle": "%svgAllInOne.formatSvg.short%"
      },
      {
        "command": "svgAllInOne.extractPalette",
        "title": "%svgAllInOne.extractPalette.title%",
        "shortTitle": "%svgAllInOne.extractPalette.short%"
      },
      {
        "command": "svgAllInOne.editAttribute",
        "title": "%svgAllInOne.editAttribute.title%",
        "shortTitle": "%svgAllInOne.editAttribute.short%"
      },
      {
        "command": "svgAllInOne.addAttribute",
        "title": "%svgAllInOne.addAttribute.title%",
        "shortTitle": "%svgAllInOne.addAttribute.short%"
      },
      {
        "command": "svgAllInOne.removeAttribute",
        "title": "%svgAllInOne.removeAttribute.title%",
        "shortTitle": "%svgAllInOne.removeAttribute.short%"
      }
    ],
    "views": {
      "explorer": [
        {
          "icon": "./resources/marketplace/icon.svg",
          "id": "svgAllInOne.attributePanel",
          "name": "%svgAllInOne.attributePanel.name%"
        }
      ]
    },
    "menus": {
      "editor/title": [
        {
          "command": "svgAllInOne.openPanel",
          "when": "resourceExtname == .svg",
          "group": "navigation@1"
        },
        {
          "command": "svgAllInOne.exportPng",
          "when": "resourceExtname == .svg",
          "group": "navigation@2"
        }
      ],
      "explorer/context": [
        {
          "command": "svgAllInOne.openPanel",
          "when": "resourceExtname == .svg",
          "group": "navigation"
        },
        {
          "command": "svgAllInOne.exportPng",
          "when": "resourceExtname == .svg",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "svgAllInOne.addAttribute",
          "when": "view == svgAllInOne.attributePanel",
          "group": "navigation@1"
        },
        {
          "command": "svgAllInOne.removeAttribute",
          "when": "view == svgAllInOne.attributePanel",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "svgAllInOne.editAttribute",
          "when": "view == svgAllInOne.attributePanel && viewItem == svgAttribute",
          "group": "inline@1"
        },
        {
          "command": "svgAllInOne.removeAttribute",
          "when": "view == svgAllInOne.attributePanel && viewItem == svgAttribute",
          "group": "inline@2"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "package:vsix": "node scripts/vsce-npm-release.cjs package",
    "publish:vsix": "node scripts/vsce-npm-release.cjs publish",
    "package:vsix:no-deps": "npx @vscode/vsce package --no-dependencies",
    "publish:vsix:no-deps": "npx @vscode/vsce publish --no-dependencies"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@vscode/l10n": "^0.0.18",
    "@xmldom/xmldom": "^0.8.10",
    "svgo": "^3.3.2",
    "xml-formatter": "^3.6.7"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/vscode": "^1.95.0",
    "@vscode/l10n-dev": "^0.0.35",
    "typescript": "^5.8.2"
  }
}
